<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="One Leg of Mission">

      <StoreActiveGoal input_goal="{goal}" stored_goal="{active_goal}"/>

      <RecoveryNode number_of_retries="10" name="NavigateRecovery">

        <PipelineSequence name="NavigateWithReplanning">

          <RateController hz="1.0">
            <ComputePathToPose goal="{active_goal}" path="{path}" planner_id="StraightLine"/>
          </RateController>

          <FollowPath path="{path}" controller_id="LongStraightLine" goal_checker_id="goal_checker"/>

        </PipelineSequence>

        <!-- No GoalUpdated: mission uses strict sequential waypoints; new goals cancel/restart the
             tree. Recovery only waits and retries {active_goal}. -->
        <Wait wait_duration="2.0"/>

      </RecoveryNode>

      <Fallback name="IceStationProcessGate">
        <Sequence name="IceStationExecution">
          <IsIceMeasurementStop goal="{active_goal}"/>

          <Sequence name="IceMeasurementSequence">
            <ReactiveFallback name="Ascend to Ice">
              <IsCloseToIce max_dist_to_ice="0.3"/>
              <MoveUpDownAction speed="0.05" elapsed_time="{ascend_duration}"/>
            </ReactiveFallback>

            <Timeout msec="60000">
              <Sequence>
                <Wait wait_duration="10.0"/>
                <RetryUntilSuccessful num_attempts="-1">
                  <Sequence>
                    <IsGPSFixGood max_xy_accuracy="2.0"/>
                    <Wait wait_duration="1.0"/>
                  </Sequence>
                </RetryUntilSuccessful>
              </Sequence>
            </Timeout>

            <ReactiveFallback name="Descend a little bit">
              <IsLongEnoughDown min_time="{ascent_duration}"/>
              <MoveUpDownAction speed="-0.05"/>
            </ReactiveFallback>
          </Sequence>
        </Sequence>

        <AlwaysSuccess/>
      </Fallback>

    </Sequence>
  </BehaviorTree>
</root>




