<!-- Fianl GoUp tree: -->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="One Leg of Mission">

      <StoreActiveGoal input_goal="{goal}" stored_goal="{active_goal}" ice_measurement_stop="{ice_measurement_stop}"/>

      <RecoveryNode number_of_retries="10" name="NavigateRecovery">

        <PipelineSequence name="NavigateWithReplanning">

          <RateController hz="0.5">
            <ComputePathToPose goal="{active_goal}" path="{path}" planner_id="StraightLine"/>
          </RateController>

          <Fallback>
            <Sequence>
              <IsSteepSlopeCheck path="{path}" min_slope="1.0" release_slope="0.2"/>
              <FollowPath path="{path}" controller_id="SteepSlope" goal_checker_id="goal_checker"/>
            </Sequence>
            <FollowPath path="{path}" controller_id="LongStraightLine" goal_checker_id="goal_checker"/>
          </Fallback>

        </PipelineSequence>

        <Wait wait_duration="2.0"/>

      </RecoveryNode>

      <Fallback name="IceStationProcessGate">
        <Sequence name="IceStationExecution">
          <IsIceMeasurementStop goal="{active_goal}" ice_measurement_stop="{ice_measurement_stop}"/>

          <Sequence name="IceMeasurementSequence">

            <!-- Ascend until touching ice; on halt writes ascent duration to blackboard "ascend_duration" -->
            <ReactiveFallback name="Ascend_Until_Ice">
              <IsCloseToIce max_dist_to_ice="0.3"/>
              <MoveUpDownAction speed="0.1"/>
            </ReactiveFallback>

            <Fallback name="GPSOrSkip">
              <Timeout msec="10000">
                <Sequence>
                  <Wait wait_duration="2.0"/>
                  <IsGPSFixGood max_xy_accuracy="2.0"/>
                </Sequence>
              </Timeout>
              <AlwaysSuccess/>
            </Fallback>

            <MoveUpDownAction speed="-0.1" elapsed_time="{ascend_duration}"/>

          </Sequence>
        </Sequence>

        <AlwaysSuccess/>
      </Fallback>

    </Sequence>
  </BehaviorTree>
</root>




