<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="10" name="NavigateRecovery">
      
      <PipelineSequence name="NavigateWithReplanning">
        
        <RateController hz="1.0"> 
          <Fallback>
            <IsStraightPathValid path="{path}" max_dist="1.5"/> 
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="StraightLine"/>
          </Fallback>
        </RateController>
        
        <Fallback>
          <Sequence>
            <IsSharpTurn path="{path}" min_angle_rad="0.785" release_angle_rad="0.0873"/>
            <FollowPath path="{path}" controller_id="SharpTurn" goal_checker_id="goal_checker"/>
          </Sequence>
          <FollowPath path="{path}" controller_id="LongStraightLine" goal_checker_id="goal_checker"/>
        </Fallback>
        
      
      </PipelineSequence>
      
      <ReactiveFallback name="RecoveryFallback">
        <GoalUpdated/>
        <Wait wait_duration="2"/>
      </ReactiveFallback>
      
    </RecoveryNode>
  </BehaviorTree>
</root>